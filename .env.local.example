# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real secrets.

# ----- Clerk (auth) -----
# From dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/report
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/report

# ----- Stripe (payment) -----
# Test mode only for now. Toggle "Test mode" in dashboard.stripe.com
# before copying these.
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# ----- Resend (email) -----
# From resend.com/api-keys
RESEND_API_KEY=re_replace_me
# Until you verify a domain on Resend, leave this as onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where report submissions get emailed
REPORT_RECIPIENT_EMAIL=jpskiermont@icloud.com

# ----- App config -----
# Base URL Stripe Checkout redirects back to.
# Locally: http://localhost:3000
# Production: https://athletematch.pages.dev (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
